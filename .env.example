# ─── Spark Backend Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values before running the server.

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=replace-with-a-generated-secret

# JWT secret key (generate separately)
JWT_SECRET_KEY=replace-with-a-generated-jwt-secret

# Stripe keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Database (SQLite default — change to postgresql://user:pass@host/db for Postgres)
DATABASE_URL=sqlite:///spark.db

# App settings
FLASK_ENV=development
FLASK_DEBUG=1
FRONTEND_URL=http://localhost:5000

# Set to 0 only when testing without OTP email verification.
REQUIRE_EMAIL_VERIFICATION=1

# Token pricing (in cents — 100 = $1.00)
TOKEN_PRICE_CENTS=8

# TURN server — required for cross-device / cross-network video calls
TURN_URL=
TURN_USER=
TURN_PASS=

# SMTP email for OTP verification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=replace-with-email@example.com
SMTP_PASSWORD=replace-with-app-password
SMTP_FROM=replace-with-email@example.com
SMTP_FROM_NAME=Spark
EMAIL_PROVIDER=smtp

# Optional: recommended on Railway if SMTP is blocked.
# Create a free Resend account, verify a sender/domain, then set these.
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# Admin dashboard
ADMIN_EMAILS=your-admin-email@example.com
